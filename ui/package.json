{
	"description": "forklift",
	"repository": {},
	"license": "Unlicense",
	"type": "module",
	"devDependencies": {
		"@types/bun": "1.3.11",
		"@types/node": "22.13.10",
		"@zoltu/file-copier": "3.0.0",
		"better-typescript-lib": "2.11.0",
		"bun-types": "1.3.11",
		"esbuild": "0.25.8",
		"typescript": "5.8.2",
		"funtypes": "5.1.1"
	},
	"dependencies": {
		"@preact/signals": "2.0.1",
		"preact": "10.26.4",
		"viem": "2.23.15"
	},
	"scripts": {
		"link-node-modules": "bun ./scripts/link-node-modules.mjs",
		"link:node-modules": "bun run link-node-modules",
		"preinstall": "bun run link-node-modules",
		"contracts": "cd ../solidity && bun run setup",
		"setup": "bun run link-node-modules && bun install --frozen-lockfile --ignore-scripts && bun run contracts && bun run build",
		"build": "tsc",
		"watch": "tsc --watch",
		"serve": "bun x tsc --project tsconfig.json && bun ./dev-server.mjs",
		"vendor": "bun run link-node-modules && bun install --frozen-lockfile --ignore-scripts && bun --tsconfig-override=tsconfig.vendor.json ./build/vendor.mts"
	}
}
