{
	"description": "forklift",
	"repository": {},
	"license": "Unlicense",
	"type": "module",
	"devDependencies": {
		"@types/bun": "1.3.11",
		"@types/node": "22.13.10",
		"@zoltu/file-copier": "3.0.0",
		"better-typescript-lib": "2.11.0",
		"bun-types": "1.3.11",
		"esbuild": "0.25.8",
		"typescript": "5.8.2",
		"funtypes": "5.1.1"
	},
	"dependencies": {
		"@preact/signals": "2.0.1",
		"buffer": "6.0.3",
		"preact": "10.26.4",
		"tevm": "1.0.0-next.149",
		"viem": "2.38.3"
	},
	"scripts": {
		"preinstall": "bun ./scripts/link-node-modules.mjs",
		"link:shared-modules": "bun ./scripts/link-node-modules.mjs",
		"contracts": "cd ../solidity && bun run setup",
		"generate:shared-js": "cd .. && bun run shared:build",
		"generate:contract-artifact": "cd .. && bun run generate:ui-contract-artifact",
		"generate:vendor": "bun install --frozen-lockfile && bun --tsconfig-override=tsconfig.vendor.json ./build/vendor.mts",
		"generate": "bun run generate:shared-js && bun run generate:contract-artifact && bun run generate:vendor",
		"setup": "bun install --frozen-lockfile && bun run contracts && bun run build",
		"shared": "cd .. && bun run shared:build && bun run ui:shared",
		"build:workers": "bun ./build/workers.mts",
		"build": "bun run shared && tsc && bun run build:workers",
		"build:tests": "bun ./build/tests.mts",
		"watch": "bun run shared && tsc --watch",
		"serve": "bun run shared && bun x tsc --project tsconfig.json && bun ./dev-server.ts",
		"vendor": "bun run generate:vendor"
	}
}
