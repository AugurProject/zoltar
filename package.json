{
	"description": "Zoltar",
	"repository": {},
	"license": "Unlicense",
	"type": "module",
	"devDependencies": {
		"@types/node": "22.13.10",
		"@types/bun": "1.3.11",
		"@typescript-eslint/eslint-plugin": "8.56.1",
		"@typescript-eslint/parser": "8.56.1",
		"@zoltu/file-copier": "3.0.0",
		"better-typescript-lib": "2.11.0",
		"esbuild": "0.25.8",
		"eslint": "8.57.0",
		"eslint-plugin-unused-imports": "4.4.1",
		"funtypes": "5.1.1",
		"globals": "15.9.0",
		"knip": "5.86.0",
		"preact": "10.26.4",
		"prettier": "3.8.1",
		"typescript": "5.8.2"
	},
	"overrides": {
		"eslint-visitor-keys": "5.0.1"
	},
	"dependencies": {
		"viem": "2.38.3"
	},
	"scripts": {
		"setup": "bun install --ignore-scripts && bun run setup-contracts",
		"setup-contracts": "cd solidity && bun run setup",
		"compile-contracts": "cd solidity && bun run compile-contracts",
		"ui:build": "bun tsc --project ui/tsconfig.json",
		"ui:serve": "bun ./ui/dev-server.mjs",
		"ui:vendor": "bun ./ui/build/vendor.mts",
		"gas-costs": "cd solidity && bun run gas-costs",
		"test-zoltar": "cd solidity && bun run test-zoltar",
		"test-peripherals": "cd solidity && bun run compile-contracts && bun run test-peripherals",
		"test-escalation-game": "cd solidity && bun run compile-contracts && bun run test-escalation-game",
		"test-question-data": "cd solidity && bun run compile-contracts && bun run test-question-data",
		"test-auction": "cd solidity && bun run compile-contracts && bun run test-auction",
		"test": "cd solidity && bun run test",
		"lint": "bun x eslint . --config eslint.config.js",
		"lint:fix": "bun x eslint . --config eslint.config.js --fix",
		"format": "bun x prettier --write solidity/ts/**/*.ts ui/ts/**/*.ts ui/ts/**/*.tsx ui/css/**/*.css && bun x eslint . --config eslint.config.js --fix",
		"knip": "bun x knip",
		"knip:fix": "bun x knip --fix"
	}
}
