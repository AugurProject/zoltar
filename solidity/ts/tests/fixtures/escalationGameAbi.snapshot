event CarriedDepositClaimed(uint8 outcome,address depositor,uint256 amount,uint256 parentDepositIndex,uint256 sourceNodeId,bytes32 leafHash)
event ClaimDeposit(address depositor,uint8 outcome,uint256 parentDepositIndex,uint256 originalDepositAmount,uint256 amountToWithdraw,uint256 burnAmount,bool transferredRep)
event DepositOnOutcome(address depositor,uint8 outcome,uint256 amount,uint256 depositIndex,uint256 cumulativeAmount,uint256 escrowedRepByVault,uint256 totalEscrowedRep)
event ForkCarrySnapshotInitialized(uint256[3] snapshotLeafCounts,uint256[3] inheritedTotals,bytes32[3] inheritedNullifierRoots)
event ForkContinuationResumed(uint256 resumedAt)
event ForkedEscrowClaimed(address depositor,uint8 outcome,uint256 sourcePrincipalClaimed,uint256 childRepClaimed)
event ForkedEscrowExported(address vault,address repReceiver,uint256[3] sourcePrincipalByOutcome,uint256[3] childRepByOutcome,uint256 totalChildRepToTransfer,bool transferredRep)
event ForkedEscrowRecorded(address depositor,uint8 outcome,uint256 sourcePrincipalTotal,uint256 childRepTotal,uint256 escrowedRepByVault,uint256 totalEscrowedRep,uint256 outcomeBalance)
event GameContinuedFromFork(uint256 startBond,uint256 nonDecisionThreshold,uint256 elapsedAtFork)
event GameStarted(uint256 activationTime,uint256 startBond,uint256 nonDecisionThreshold)
event LocalDepositAppended(uint256 indexed nodeId,uint8 outcome,address depositor,uint256 amount,uint256 parentDepositIndex,uint256 cumulativeAmount)
event LocalDepositsExported(address vault,address repReceiver,uint256[3] principalByOutcome,uint256 principalToTransfer,uint256 exportCursor,bool transferredRep)
event NonDecisionReached(uint256 nonDecisionTimestamp)
event ResidualRepSweptToSecurityPool(uint256 amount)
event VaultEscrowUpdated(address vault,uint256 escrowedRepByVault,uint256 totalEscrowedRep)
event WithdrawDeposit(address depositor,uint8 outcome,uint256 amountToWithdraw,uint256 depositIndex)
function activationTime() view -> (uint256)
function claimDepositForWinning(uint256 depositIndex,uint8 outcome) nonpayable -> (address depositor,uint256 amountToWithdraw,uint256 originalDepositAmount)
function claimDepositForWinningWithoutTransfer(uint256 depositIndex,uint8 outcome) nonpayable -> (address depositor,uint256 amountToWithdraw,uint256 originalDepositAmount)
function computeIterativeAttritionCost(uint256 timeSinceStart) view -> (uint256)
function computeTimeSinceStartFromAttritionCost(uint256 attritionCost) view -> (uint256)
function drainAllRep(address receiver) nonpayable -> (uint256 amount)
function escrowedRepByVault(address) view -> (uint256)
function exportForkedEscrowByOutcome(address vault,address repReceiver) nonpayable -> (uint256[3] sourcePrincipalByOutcome,uint256[3] childRepByOutcome)
function exportForkedEscrowByOutcomeWithoutTransfer(address vault) nonpayable -> (uint256[3] sourcePrincipalByOutcome,uint256[3] childRepByOutcome)
function exportUnresolvedDeposit(tuple(address depositor,uint256 amount,uint256 parentDepositIndex,uint256 cumulativeAmount,uint256 sourceNodeId,uint256 leafIndex,bytes32[] merkleMountainRangeSiblings,uint256 merkleMountainRangePeakIndex,bytes32[] nullifierSiblings) proof,uint8 outcome) nonpayable -> (address depositor,uint256 amount,uint256 parentDepositIndex)
function exportUnresolvedDeposit(uint256 depositIndex,uint8 outcome) nonpayable -> (address depositor,uint256 amount,uint256 parentDepositIndex)
function exportVaultUnresolvedDepositAmounts(address vault,address repReceiver) nonpayable -> (uint256[3] principalByOutcome)
function exportVaultUnresolvedDepositAmountsWithoutTransfer(address vault) nonpayable -> (uint256[3] principalByOutcome)
function forkCarrySnapshotInitialized() view -> (bool)
function forkContinuation() view -> (bool)
function forkElapsedAtStart() view -> (uint256)
function forkResumedAt() view -> (uint256)
function getBindingCapital() view -> (uint256)
function getCarryLeafPageByOutcome(uint8 outcome,uint256 startNodeId,uint256 maxEntries) view -> (tuple[](address depositor,uint256 amount,uint256 parentDepositIndex,uint256 cumulativeAmount,uint256 sourceNodeId) carryLeaves,uint256 nextPageNodeId)
function getDepositsByOutcome(uint8 outcome,uint256 startIndex,uint256 numberOfEntries) view -> (tuple[](address depositor,uint256 amount,uint256 cumulativeAmount) returnDeposits)
function getDepositsByOutcomeLength(uint8 outcome) view -> (uint256)
function getEscalationGameEndDate() view -> (uint256 endTime)
function getForkCarrySnapshot() view -> (bytes32[64][3] carryPeaks,uint256[3] carryLeafCounts,uint256[3] carryTotals,bytes32[3] nullifierRoots)
function getForkedEscrowByVaultAndOutcome(address depositor,uint8 outcome) view -> (uint256 sourcePrincipal,uint256 sourcePrincipalClaimed,uint256 childRep,uint256 childRepClaimed)
function getOutcomeBalances() view -> (uint256[3] balances)
function getOutcomeState(uint8 outcome) view -> (tuple(uint256 balance,uint256 snapshotLeafCount,bytes32[64] snapshotPeaks,uint256 inheritedUnresolvedTotal,bytes32 currentNullifierRoot,uint256 localHeadNodeId,uint256 currentLeafCount,bytes32[64] currentPeaks,uint256 localUnresolvedTotal,bytes32 currentCarryRoot,uint256 currentCarryTotal) stateView)
function getProofConsumedCarriedDepositIndexesByOutcome(uint8 outcome,uint256 startIndex,uint256 numberOfEntries) view -> (uint256[] parentDepositIndexes)
function getQuestionResolution() view -> (uint8 outcome)
function hasReachedNonDecision() view -> (bool)
function hasUnexportedForkedEscrow(address vault) view -> (bool)
function hasUnexportedLocalDepositRefs(address vault) view -> (bool)
function initializeForkCarrySnapshotWithResolutionBalances(bytes32[64][3] snapshotPeaksInput,uint256[3] snapshotLeafCountsInput,uint256[3] snapshotCarryTotals,uint256[3] snapshotResolutionBalances,bytes32[3] snapshotNullifierRoots) nonpayable -> ()
function isForkCarryFundingComplete() view -> (bool)
function nodes(uint256) view -> (uint256 parentNodeId,address depositor,uint8 outcome,uint256 amount,uint256 parentDepositIndex,uint256 cumulativeAmount,uint256 carryLeafIndex)
function nonDecisionThreshold() view -> (uint256)
function nonDecisionTimestamp() view -> (uint256)
function previewDepositOnOutcome(uint8 outcome,uint256 amount) view -> (uint256 acceptedAmount,uint256 resultingCumulativeAmount)
function recordDepositFromSecurityPool(address depositor,uint8 outcome,uint256 amount,uint256 expectedCumulativeAmount) nonpayable -> (uint256 parentDepositIndex)
function recordForkedEscrowForOutcome(address depositor,uint8 outcome,uint256 sourcePrincipal,uint256 childRepAmount) nonpayable -> ()
function repToken() view -> (address)
function resumeFromFork() nonpayable -> ()
function securityPool() view -> (address)
function start(uint256 _startBond,uint256 _nonDecisionThreshold) nonpayable -> ()
function startBond() view -> (uint256)
function startFromFork(uint256 _startBond,uint256 _nonDecisionThreshold,uint256 elapsedAtFork) nonpayable -> ()
function sweepResidualRepToSecurityPool() nonpayable -> ()
function totalCost() view -> (uint256)
function totalEscrowedRep() view -> (uint256)
function withdrawDeposit(tuple(address depositor,uint256 amount,uint256 parentDepositIndex,uint256 cumulativeAmount,uint256 sourceNodeId,uint256 leafIndex,bytes32[] merkleMountainRangeSiblings,uint256 merkleMountainRangePeakIndex,bytes32[] nullifierSiblings) proof,uint8 outcome) nonpayable -> (address depositor,uint256 amountToWithdraw,uint256 originalDepositAmount)
function withdrawDeposit(uint256 depositIndex,uint8 outcome) nonpayable -> (address depositor,uint256 amountToWithdraw,uint256 originalDepositAmount)
